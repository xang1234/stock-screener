mcp_servers:
  stockscreen_market:
    url: "http://backend:8000/mcp/"
    headers:
      x-server-auth: "REPLACE_WITH_SERVER_AUTH_PASSWORD"
    tools:
      include:
        - market_overview
        - compare_feature_runs
        - find_candidates
        - explain_symbol
        - watchlist_snapshot
        - watchlist_add
        - theme_state
        - task_status
        - group_rankings
        - stock_lookup
        - stock_snapshot
        - breadth_snapshot
        - daily_digest
      prompts: false
      resources: false

skills:
  external_dirs:
    - /opt/external-skills
