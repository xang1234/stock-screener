# =============================================================================
# Docker Deployment Environment Configuration
# =============================================================================
# Copy this file to .env.docker and configure for your deployment scenario.
#
# Usage:
#   Local dev:  docker-compose up (no .env.docker needed)
#   Homelab:    docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#   VPS+HTTPS:  docker-compose -f docker-compose.yml -f docker-compose.prod.yml -f docker-compose.https.yml up -d
#   GHCR image release:
#               docker-compose -f docker-compose.yml -f docker-compose.prod.yml -f docker-compose.release.yml up -d --no-build
#
# =============================================================================

# -----------------------------------------------------------------------------
# DEPLOYMENT CONFIGURATION
# -----------------------------------------------------------------------------

# Domain name for HTTPS deployment (VPS scenario only)
# Used by Caddy to obtain Let's Encrypt certificate
# Example: stocks.yourdomain.com
DOMAIN=

# -----------------------------------------------------------------------------
# OPTIONAL: GHCR IMAGE RELEASES
# -----------------------------------------------------------------------------

# When using docker-compose.release.yml, point these at the GitHub Container
# Registry images published by GitHub Actions and pin the release tag to deploy.
# Example:
# BACKEND_IMAGE=ghcr.io/your-org/stockscreenclaude-backend
# FRONTEND_IMAGE=ghcr.io/your-org/stockscreenclaude-frontend
# APP_IMAGE_TAG=v1.2.3
BACKEND_IMAGE=
FRONTEND_IMAGE=
APP_IMAGE_TAG=

# CORS allowed origins (comma-separated)
# For local dev: http://localhost,http://localhost:80
# For homelab: https://stocks.home.lan
# For VPS: https://stocks.yourdomain.com
CORS_ORIGINS=http://localhost,http://localhost:80

# Force Secure session cookies when TLS terminates upstream of the backend/nginx.
# Set true behind a trusted HTTPS reverse proxy. The HTTPS Caddy overlay enables this automatically.
SERVER_AUTH_SECURE_COOKIE=false

# Keep API docs disabled on public/server deployments unless you explicitly need them.
SERVER_EXPOSE_API_DOCS=false

# -----------------------------------------------------------------------------
# LLM API KEYS (at least one required for chatbot)
# Docker Compose reads these from the project root env source (.env or --env-file),
# not from backend/.env inside the image.
# -----------------------------------------------------------------------------

# Z.AI - OpenAI-compatible endpoint for GLM models
# Get key at: https://platform.z.ai
ZAI_API_KEY=
# Multiple Z.AI keys for load balancing (comma-separated, optional)
ZAI_API_KEYS=
ZAI_API_BASE=https://api.z.ai/api/paas/v4

# Minimax - International API (default for theme extraction)
# Get key at: https://platform.minimax.io
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# Groq - Fast inference, free tier available (recommended for start)
# Get key at: https://console.groq.com
GROQ_API_KEY=
# Multiple Groq keys for load balancing (comma-separated, optional)
GROQ_API_KEYS=

# Google Gemini - For theme extraction
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alternative name (either works)
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# WEB SEARCH API KEYS (optional, enables research mode)
# -----------------------------------------------------------------------------

# Tavily - Primary web search for chatbot research mode
# Get key at: https://tavily.com
TAVILY_API_KEY=

# Serper - Fallback web search
# Get key at: https://serper.dev
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# DATA SOURCE API KEYS
# -----------------------------------------------------------------------------

# Alpha Vantage - Fundamental data (free tier: 25 requests/day)
# Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# -----------------------------------------------------------------------------
# LLM ROUTING CONFIGURATION (optional, sensible defaults provided)
# -----------------------------------------------------------------------------

# Primary LLM provider: groq, zai, minimax, gemini
LLM_DEFAULT_PROVIDER=groq

# Model for chatbot (LiteLLM format: provider/model)
LLM_CHATBOT_MODEL=groq/qwen-qwen3-32b

# Model for research agents
LLM_RESEARCH_MODEL=groq/qwen-qwen3-32b

# Enable automatic fallback to other providers on failure
LLM_FALLBACK_ENABLED=true

# Fallback model chain (comma-separated, tried in order)
LLM_FALLBACK_MODELS=groq/llama-3.3-70b-versatile,gemini/gemini-2.0-flash

# -----------------------------------------------------------------------------
# INTERNAL CONFIGURATION (usually no changes needed)
# -----------------------------------------------------------------------------

# Database (Docker uses PostgreSQL)
POSTGRES_DB=stockscanner
POSTGRES_USER=stockscanner
POSTGRES_PASSWORD=stockscanner
DATABASE_URL=postgresql://stockscanner:stockscanner@postgres:5432/stockscanner

# Redis connection (internal Docker network)
REDIS_HOST=redis
REDIS_PORT=6379

# Celery configuration (internal Docker network)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Celery Beat timezone for scheduled tasks (IANA format)
# All schedule hours (cache_warm_hour, etc.) are written in this timezone
CELERY_TIMEZONE=America/New_York

# Server binding (internal, nginx handles external)
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=80

# Required shared password for browser login in server/Docker deployments
SERVER_AUTH_PASSWORD=

# Optional session-signing secret (defaults to SERVER_AUTH_PASSWORD if unset)
SERVER_AUTH_SESSION_SECRET=

# Admin API key for config endpoints (/api/v1/config/*)
ADMIN_API_KEY=

# Hermes assistant sidecar (internal only)
HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_API_BASE=http://hermes:8642/v1
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
HERMES_REQUEST_TIMEOUT_SECONDS=120
# Optional override when you want Hermes to prefer a specific provider
# instead of auto-detecting from the keys below.
# Examples: minimax, zai, openrouter, custom
HERMES_INFERENCE_PROVIDER=
# Hermes publishes amd64-only images today; keep this default on Apple Silicon
# unless/until a native arm64 image is available.
HERMES_PLATFORM=linux/amd64

# Hermes runtime inference credentials.
# Set at least one of these for the assistant sidecar itself:
#   - MINIMAX_API_KEY
#   - ZAI_API_KEY (defined above) or GLM_API_KEY
#   - OPENROUTER_API_KEY
#   - OPENAI_API_KEY with OPENAI_BASE_URL for a custom OpenAI-compatible endpoint
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
GLM_API_KEY=
Z_AI_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4

# -----------------------------------------------------------------------------
# OPTIONAL: Social/News API Keys
# -----------------------------------------------------------------------------

# Twitter/X ingestion. Official X API is the default provider.
# Set X_INGEST_PROVIDER=xui to override with private https://github.com/xang1234/xui.
X_INGEST_PROVIDER=official
TWITTER_BEARER_TOKEN=
X_API_MAX_PAGES_PER_SOURCE=10
X_API_MAX_RESULTS_PER_PAGE=50

# Legacy repo-local xui-reader/session bridge settings.
XUI_ENABLED=false
XUI_CONFIG_PATH=/app/data/xui-reader/config.toml
XUI_PROFILE=default
XUI_LIMIT_PER_SOURCE=50
XUI_NEW_ONLY=true
XUI_CHECKPOINT_MODE=auto
XUI_BRIDGE_ENABLED=false
XUI_BRIDGE_ALLOWED_ORIGINS=http://localhost:80,http://127.0.0.1:80,http://localhost:5173,http://127.0.0.1:5173
XUI_BRIDGE_CHALLENGE_TTL_SECONDS=120
XUI_BRIDGE_MAX_COOKIES=300
TWITTER_REQUEST_DELAY=5.0

# Benzinga API (optional, for news)
BENZINGA_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL: Advanced Configuration
# -----------------------------------------------------------------------------

# SEC EDGAR user agent (required for SEC filings)
# Format: AppName/Version (contact@email.com)
SEC_USER_AGENT=StockScanner/1.0 (contact@example.com)

# Cache TTL settings (seconds)
PRICE_CACHE_TTL=604800
FUNDAMENTAL_CACHE_TTL=604800
QUARTERLY_CACHE_TTL=2592000

# Markets whose worker containers should be started by Docker Compose.
# This is the deployment worker set; runtime.enabled_markets in Postgres still
# gates task execution. To add a market later, update this value and recreate
# the stack with scripts/docker-compose-enabled-markets.sh up -d.
ENABLED_MARKETS=US

# Data fetch lock (seconds to wait before failing)
DATA_FETCH_LOCK_WAIT_SECONDS=7200

# Deep research safety limits
RESEARCH_READ_URL_MAX_BYTES=5000000

# Setup Engine scanner feature flag (set to false to disable)
SETUP_ENGINE_ENABLED=true

# Optional one-time cleanup for legacy scan universes
INVALID_UNIVERSE_CLEANUP_ENABLED=false
