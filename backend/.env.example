# =============================================================================
# Stock Scanner Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
# For Docker deployment, see .env.docker.example in the project root.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API KEYS (required for assistant + extraction workflows)
# For local backend runs, these values come from backend/.env.
# Docker Compose uses root-level env substitution instead of backend/.env.
# -----------------------------------------------------------------------------

# Z.AI - OpenAI-compatible endpoint for GLM models
# Get key at: https://platform.z.ai
ZAI_API_KEY=
# Multiple Z.AI keys for load balancing (comma-separated, optional)
ZAI_API_KEYS=
ZAI_API_BASE=https://api.z.ai/api/paas/v4

# Minimax - International API (default for theme extraction)
# Get key at: https://platform.minimax.io
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1

# Groq - Fast inference, free tier available (recommended)
# Get key at: https://console.groq.com
GROQ_API_KEY=
# Multiple Groq keys for load balancing (comma-separated, optional)
GROQ_API_KEYS=

# -----------------------------------------------------------------------------
# WEB SEARCH API KEYS (optional, enables research mode)
# -----------------------------------------------------------------------------

# Tavily - Primary web search for assistant research
# Get key at: https://tavily.com
TAVILY_API_KEY=

# Serper - Fallback web search
# Get key at: https://serper.dev
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# DATA SOURCE API KEYS
# -----------------------------------------------------------------------------

# Alpha Vantage - Fundamental data (free tier: 25 requests/day)
# Get key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost/stockscanner

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------

API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Shared password for browser login when running backend in server mode
SERVER_AUTH_PASSWORD=

# Optional cookie-signing secret (defaults to SERVER_AUTH_PASSWORD)
SERVER_AUTH_SESSION_SECRET=

# Force Secure session cookies when TLS terminates at a trusted HTTPS proxy
SERVER_AUTH_SECURE_COOKIE=false

# Keep docs available on trusted local development runs. Docker/server deployments should leave this false.
SERVER_EXPOSE_API_DOCS=true

# Set to false only for trusted local development when you explicitly want no auth
SERVER_AUTH_ENABLED=true

# Admin API key for config endpoints (/api/v1/config/*)
ADMIN_API_KEY=

# Internal Hermes assistant gateway (backend-only, never browser-facing)
HERMES_API_BASE=http://127.0.0.1:8642/v1
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
HERMES_REQUEST_TIMEOUT_SECONDS=120

# MCP server identity for Hermes / other MCP clients
MCP_SERVER_NAME=stockscreen-market-copilot

# Keep false unless you explicitly want MCP clients to modify watchlists
MCP_WATCHLIST_WRITES_ENABLED=false

# Enable the Streamable HTTP MCP transport at /mcp (disable to keep stdio-only)
MCP_HTTP_ENABLED=true

# -----------------------------------------------------------------------------
# REDIS / CELERY
# -----------------------------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Celery Beat timezone for scheduled tasks (IANA format)
# All schedule hours (cache_warm_hour, etc.) are written in this timezone
CELERY_TIMEZONE=America/New_York

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

YFINANCE_RATE_LIMIT=1
ALPHAVANTAGE_RATE_LIMIT=25

# Official exchange universe refresh sources for HK / JP / TW
HK_UNIVERSE_SOURCE_URL=https://www.hkex.com.hk/eng/services/trading/securities/securitieslists/ListOfSecurities.xlsx
JP_UNIVERSE_SOURCE_URL=https://www.jpx.co.jp/markets/statistics-equities/misc/tvdivq0000001vg2-att/data_j.xls
TW_UNIVERSE_ALLOW_INSECURE_FALLBACK=false
TW_UNIVERSE_SOURCE_TPEX_URL=https://isin.twse.com.tw/isin/e_C_public.jsp?strMode=4
TW_UNIVERSE_SOURCE_TWSE_URL=https://isin.twse.com.tw/isin/e_C_public.jsp?strMode=2
UNIVERSE_SOURCE_TIMEOUT_SECONDS=60
UNIVERSE_SOURCE_USER_AGENT=StockScannerUniverseRefresh/1.0

# -----------------------------------------------------------------------------
# SCANNING CONFIGURATION
# -----------------------------------------------------------------------------

DEFAULT_UNIVERSE=all
SCAN_BATCH_SIZE=20
CACHE_TTL_HOURS=24

# Setup Engine scanner feature flag (set to false to disable)
SETUP_ENGINE_ENABLED=true

# -----------------------------------------------------------------------------
# DATA FETCH LOCK
# -----------------------------------------------------------------------------

# Max time to wait for serialized data fetch lock (seconds)
DATA_FETCH_LOCK_WAIT_SECONDS=7200

# -----------------------------------------------------------------------------
# OPTIONAL: Social/News APIs
# -----------------------------------------------------------------------------

# Twitter/X ingestion. Official X API is the default provider.
# Set X_INGEST_PROVIDER=xui to override with private https://github.com/xang1234/xui.
X_INGEST_PROVIDER=official
TWITTER_BEARER_TOKEN=
X_API_MAX_PAGES_PER_SOURCE=10

# Legacy repo-local xui-reader/session bridge settings.
XUI_ENABLED=false
XUI_CONFIG_PATH=../data/xui-reader/config.toml
XUI_PROFILE=default
XUI_LIMIT_PER_SOURCE=50
XUI_NEW_ONLY=true
XUI_CHECKPOINT_MODE=auto
XUI_BRIDGE_ENABLED=false
XUI_BRIDGE_ALLOWED_ORIGINS=http://localhost:80,http://127.0.0.1:80,http://localhost:5173,http://127.0.0.1:5173
XUI_BRIDGE_CHALLENGE_TTL_SECONDS=120
XUI_BRIDGE_MAX_COOKIES=300

# Delay between twitter source fetches (seconds)
TWITTER_REQUEST_DELAY=5.0

# Benzinga API (optional)
BENZINGA_API_KEY=
